<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<!-- Webbing & Load-Bearing Equipment -->

	<!-- Infantry Webbing -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Infantry"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Infantry"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets>
				<CarryBulk>15</CarryBulk>
				<ReloadSpeed>0.15</ReloadSpeed>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Infantry"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Shoulders</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Infantry"]/apparel/layers</xpath>
		<value>
			<layers>
				<li>Webbing</li>
			</layers>
		</value>
	</Operation>

	<!-- Engineer Webbing -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Engineer"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Engineer"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets>
				<CarryBulk>12</CarryBulk>
				<FixBrokenDownBuildingSuccessChance>0.1</FixBrokenDownBuildingSuccessChance>
				<ConstructionSpeed>0.15</ConstructionSpeed>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Engineer"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Shoulders</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Engineer"]/apparel/layers</xpath>
		<value>
			<layers>
				<li>Webbing</li>
			</layers>
		</value>
	</Operation>

	<!-- Medic Webbing -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Medic"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Medic"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets>
				<CarryBulk>12</CarryBulk>
				<MedicalTendSpeed>0.15</MedicalTendSpeed>
				<MedicalTendQuality>0.10</MedicalTendQuality>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Medic"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Shoulders</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Webbing_Medic"]/apparel/layers</xpath>
		<value>
			<layers>
				<li>Webbing</li>
			</layers>
		</value>
	</Operation>

</Patch>
