<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_HeavyCarapaceArmor"]/statBases</xpath>
		<value>
			<Bulk>35</Bulk>
			<WornBulk>10</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_HeavyCarapaceArmor"]/statBases/MaxHitPoints</xpath>
		<value>
			<MaxHitPoints>450</MaxHitPoints>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_HeavyCarapaceArmor"]/statBases/Mass</xpath>
		<value>
			<Mass>13</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_HeavyCarapaceArmor"]/statBases</xpath>
		<value>
			<Flammability>0.2</Flammability>
			<ArmorRating_Sharp>18</ArmorRating_Sharp>
			<ArmorRating_Blunt>40</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_HeavyCarapaceArmor"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets>
				<CarryWeight>60</CarryWeight>
				<CarryBulk>12</CarryBulk>
				<MoveSpeed>-0.07</MoveSpeed>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_HeavyCarapaceArmor"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Hands</li>
			<li>Feet</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="EOTF_HeavyCarapaceArmor"]</xpath>
		<value>
			<li Class="CombatExtended.PartialArmorExt">
				<stats>
					<li>
						<ArmorRating_Sharp>0.60</ArmorRating_Sharp>
						<parts>
							<li>Neck</li>
							<li>Hand</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.60</ArmorRating_Blunt>
						<parts>
							<li>Neck</li>
							<li>Hand</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.85</ArmorRating_Sharp>
						<parts>
							<li>Leg</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.85</ArmorRating_Blunt>
						<parts>
							<li>Leg</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.75</ArmorRating_Sharp>
						<parts>
							<li>Arm</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.75</ArmorRating_Blunt>
						<parts>
							<li>Arm</li>
						</parts>
					</li>
				</stats>
			</li>
		</value>
	</Operation>

