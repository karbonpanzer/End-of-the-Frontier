<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<!-- Officer Uniforms - Prestige/Command Clothing -->

	<!-- Frontier Officer Uniform (Standard) -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Officer_Uniform"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>0</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Officer_Uniform"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>0.4</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Officer Cap (Standard) -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Officer_Cap"]/statBases</xpath>
		<value>
			<Bulk>0.5</Bulk>
			<WornBulk>0</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Officer_Cap"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Frontier Officer Uniform (Winter/Polar) -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_Officer_Uniform_Winter"]/statBases</xpath>
		<value>
			<Bulk>3</Bulk>
			<WornBulk>0</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_Officer_Uniform_Winter"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>0.4</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Officer Cap (Polar) -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_OfficerCap_Polar"]/statBases</xpath>
		<value>
			<Bulk>1</Bulk>
			<WornBulk>0</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_OfficerCap_Polar"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
		</value>
	</Operation>

</Patch>
