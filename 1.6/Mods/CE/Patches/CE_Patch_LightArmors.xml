<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<!-- Light Carapace Armor Series - CE Patches -->

	<!-- Carapace Armor (Standard) -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_CarapaceArmor"]/statBases</xpath>
		<value>
			<Bulk>25</Bulk>
			<WornBulk>5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_CarapaceArmor"]/statBases/MaxHitPoints</xpath>
		<value>
			<MaxHitPoints>350</MaxHitPoints>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_CarapaceArmor"]/statBases/Mass</xpath>
		<value>
			<Mass>8</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_CarapaceArmor"]/statBases</xpath>
		<value>
			<Flammability>0.3</Flammability>
			<ArmorRating_Sharp>15</ArmorRating_Sharp>
			<ArmorRating_Blunt>32</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="EOTF_CarapaceArmor"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets>
				<CarryWeight>45</CarryWeight>
				<CarryBulk>8</CarryBulk>
				<MoveSpeed>-0.04</MoveSpeed>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="EOTF_CarapaceArmor"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Hands</li>
			<li>Feet</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="EOTF_CarapaceArmor"]</xpath>
		<value>
			<li Class="CombatExtended.PartialArmorExt">
				<stats>
					<li>
						<ArmorRating_Sharp>0.55</ArmorRating_Sharp>
						<parts>
							<li>Neck</li>
							<li>Hand</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.55</ArmorRating_Blunt>
						<parts>
							<li>Neck</li>
							<li>Hand</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.80</ArmorRating_Sharp>
						<parts>
							<li>Leg</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.80</ArmorRating_Blunt>
						<parts>
							<li>Leg</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.70</ArmorRating_Sharp>
						<parts>
							<li>Arm</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.70</ArmorRating_Blunt>
						<parts>
							<li>Arm</li>
						</parts>
					</li>
				</stats>
			</li>
		</value>
	</Operation>

