<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- FIRST OFFER: Basic labor contract -->
  <QuestScriptDef>
    <defName>LaborContract_Offer1</defName>
    <rootSelectionWeight>1.0</rootSelectionWeight>
    <expireDaysRange>4~8</expireDaysRange>
    
    <questNameRules>
      <rulesStrings>
        <li>questName->Colonist Outsourcing</li>
        <li>questName->Contract Workers</li>
        <li>questName->Temporary Workers</li>
        <li>questName->Worker Lending</li>
        <li>questName->Workers for [asker_faction_name]</li>
        <li>questName->Provisional Workers</li>
        <li>questName->Requesting Workers</li>
      </rulesStrings>
    </questNameRules>
    
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->[asker_nameFull], [asker_faction_leaderTitle] of [asker_faction_name], needs extra hands to help [dutyDescription].

[asker_pronoun] is asking you to lend [asker_objective] [colonistsToLendCount] for [lendForDays] days.

[asker_pronoun] will send a shuttle to pick up the [colonistWord].</li>

        <!-- Random duty descriptions (vanilla style) -->
        <li>dutyDescription->gather the harvest</li>
        <li>dutyDescription->fortify a settlement</li>
        <li>dutyDescription->set up a settlement</li>
        <li>dutyDescription->watch for raiders</li>
        <li>dutyDescription->set up a hospital</li>
        <li>dutyDescription->work the mines</li>
        <li>dutyDescription->repair damaged structures</li>
        <li>dutyDescription->tend the fields</li>
        <li>dutyDescription->prepare meals for workers</li>
        <li>dutyDescription->treat the sick</li>
        <li>dutyDescription->produce needed goods</li>
        <li>dutyDescription->conduct research</li>

        <!-- Colonist singular/plural -->
        <li>colonistWord(colonistsToLendCount==1)->colonist</li>
        <li>colonistWord(colonistsToLendCount>1)->colonists</li>

        <li>pawnListHaveConjugation(colonistsToLendCount==1)->has</li>
        <li>pawnListHaveConjugation(colonistsToLendCount>1)->have</li>
      </rulesStrings>
    </questDescriptionRules>
    
    <root Class="QuestNode_Sequence">
      <nodes>
        
        <!-- Vanilla pattern: randomize challenge rating -->
        <li Class="QuestNode_SubScript">
          <def>Util_RandomizePointsChallengeRating</def>
        </li>

        <!-- Calculate colonist count to lend (vanilla pattern from PawnLend) -->
        <li Class="QuestNode_GetRandomInRangeForChallengeRating">
          <storeAs>colonyPercentageToLend</storeAs>
          <oneStarRange>0.0~0.35</oneStarRange>
          <twoStarRange>0.36~0.6</twoStarRange>
          <threeStarRange>0.61~0.75</threeStarRange>
        </li>

        <li Class="QuestNode_GetColonistCountFromColonyPercentage">
          <storeAs>colonistsToLendCount</storeAs>
          <colonyPercentage>$colonyPercentageToLend</colonyPercentage>
          <mustHaveFreeColonistsAvailableCount>2</mustHaveFreeColonistsAvailableCount>
        </li>

        <li Class="QuestNode_GetMap">
          <preferMapWithMinFreeColonists>$colonistsToLendCount</preferMapWithMinFreeColonists>
        </li>

        <!-- End if map removed before quest accepted -->
        <li Class="QuestNode_End">
          <inSignal>map.MapRemoved</inSignal>
          <outcome>Fail</outcome>
          <signalListenMode>NotYetAcceptedOnly</signalListenMode>
        </li>

        <li Class="QuestNode_GetPawn">
          <storeAs>asker</storeAs>
          <mustBeFactionLeader>true</mustBeFactionLeader>
          <allowPermanentEnemyFaction>false</allowPermanentEnemyFaction>
          <minTechLevel>Industrial</minTechLevel>
          <hostileWeight>0.15</hostileWeight>
        </li>

        <!-- Calculate days to lend colonists for (vanilla pattern) -->
        <li Class="QuestNode_GetRandomInRangeForChallengeRating">
          <storeAs>lendForDays</storeAs>
          <oneStarRange>5~10</oneStarRange>
          <twoStarRange>10~20</twoStarRange>
          <threeStarRange>20~30</threeStarRange>
          <roundRandom>true</roundRandom>
        </li>

        <!-- Calculate reward from colonistsToLendCount * lendForDays (vanilla pattern) -->
        <li Class="QuestNode_EvaluateSimpleCurve">
          <value>$($colonistsToLendCount*$lendForDays)</value>
          <storeAs>rewardValue</storeAs>
          <curve>
            <points>
              <li>5, 400</li>
              <li>50, 1200</li>
              <li>200, 3000</li>
            </points>
          </curve>
        </li>

        <!-- Vanilla pattern: resolve duty description now for use in return letter -->
        <li Class="QuestNode_ResolveTextNow">
          <root>dutyDescription</root>
          <storeAs>dutyDescription</storeAs>
        </li>

        <!-- Vanilla pattern: shuttle arrives -->
        <li Class="QuestNode_ShuttleDelay">
          <delayTicks>3500</delayTicks>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_SubScript">
                <def>Util_TransportShip_Pickup</def>
                <parms>
                  <leaveDelayTicks>60000</leaveDelayTicks>
                  <leaveImmediatelyWhenSatisfied>true</leaveImmediatelyWhenSatisfied>
                  <acceptColonists>true</acceptColonists>
                  <onlyAcceptColonists>true</onlyAcceptColonists>
                  <onlyAcceptHealthy>true</onlyAcceptHealthy>
                  <requireColonistCount>$colonistsToLendCount</requireColonistCount>
                </parms>
              </li>

              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleArrived">Shuttle arrived</label>
                <text TKey="LetterTextShuttleArrived">The shuttle has arrived to collect [colonistsToLendCount] of your colonists.</text>
                <lookTargets>$pickupShipThing</lookTargets>
              </li>
            </nodes>
          </node>
        </li>

        <!-- Vanilla pattern: shuttle destroyed -->
        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleDestroyed">Shuttle destroyed</label>
                <text TKey="LetterTextShuttleDestroyed">The shuttle sent to collect colonists has been destroyed.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <!-- Vanilla pattern: shuttle abandoned -->
        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.LeftBehind</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleDestroyed">Shuttle abandoned</label>
                <text TKey="LetterTextShuttleDestroyed">The shuttle sent to collect colonists has been left behind.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <!-- Vanilla pattern: shuttle sent away with colonists -->
        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.SentSatisfied</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_LendColonistsToFaction">
                <shuttle>$pickupShipThing</shuttle>
                <lendColonistsToFactionOf>$asker</lendColonistsToFactionOf>
                <returnLentColonistsInTicks>$($lendForDays*60000)</returnLentColonistsInTicks>
                <outSignalComplete>ColonistsReturned</outSignalComplete>
                <outSignalColonistsDied>ColonistsDied</outSignalColonistsDied>
              </li>
              
              <!-- Give rewards after small delay -->
              <li Class="QuestNode_Delay">
                <delayTicks>$(randInt(300,600))</delayTicks>
                <node Class="QuestNode_GiveRewards">
                  <parms>
                    <allowGoodwill>true</allowGoodwill>
                    <allowRoyalFavor>false</allowRoyalFavor>
                  </parms>
                </node>
              </li>
            </nodes>
          </node>
        </li>

        <!-- Vanilla pattern: colonists returned -->
        <li Class="QuestNode_Signal">
          <inSignal>ColonistsReturned</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelColonistsReturned">Colonists returned</label>
                <text TKey="LetterTextReturnAfterHelping">{PAWNS} [pawnListHaveConjugation] returned after helping [asker_nameFull] of [asker_faction_name] to [dutyDescription].</text>
                <letterDef>PositiveEvent</letterDef>
              </li>
              <li Class="QuestNode_End">
                <outcome>Success</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <!-- Vanilla pattern: colonists died -->
        <li Class="QuestNode_Signal">
          <inSignal>ColonistsDied</inSignal>
          <node Class="QuestNode_End">
            <outcome>Success</outcome>
          </node>
        </li>

        <!-- CUSTOM: Trigger second offer when declined -->
        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.SentUnsatisfied</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <!-- Wait 12-16 days, then send better offer -->
              <li Class="QuestNode_Delay">
                <delayTicks>$(randInt(12,16)*60000)</delayTicks>
                <node Class="QuestNode_GenerateQuest">
                  <questScriptDef>LaborContract_Offer2</questScriptDef>
                  <slate>
                    <asker>$asker</asker>
                    <colonistsToLendCount>$colonistsToLendCount</colonistsToLendCount>
                    <lendForDays>$lendForDays</lendForDays>
                    <dutyDescription>$dutyDescription</dutyDescription>
                  </slate>
                </node>
              </li>
              
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>
        
      </nodes>
    </root>
  </QuestScriptDef>

  <!-- SECOND OFFER: Better deal + bonus colonist -->
  <QuestScriptDef>
    <defName>LaborContract_Offer2</defName>
    <rootSelectionWeight>0</rootSelectionWeight> <!-- Only triggered by first quest -->
    <expireDaysRange>4~8</expireDaysRange>
    
    <questNameRules>
      <rulesStrings>
        <li>questName->Improved Offer: [asker_faction_name]</li>
        <li>questName->Counter-Offer from [asker_faction_name]</li>
        <li>questName->Revised Contract Terms</li>
      </rulesStrings>
    </questNameRules>
    
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->[asker_nameFull] of [asker_faction_name] has reconsidered their offer.

[asker_pronoun] is now offering improved payment, PLUS an experienced colonist from their faction will join you.

Still needs [colonistsToLendCount] for [lendForDays] days to [dutyDescription].</li>

        <li>colonistWord(colonistsToLendCount==1)->colonist</li>
        <li>colonistWord(colonistsToLendCount>1)->colonists</li>

        <li>pawnListHaveConjugation(colonistsToLendCount==1)->has</li>
        <li>pawnListHaveConjugation(colonistsToLendCount>1)->have</li>
      </rulesStrings>
    </questDescriptionRules>
    
    <root Class="QuestNode_Sequence">
      <nodes>
        
        <!-- Retrieve values passed from Offer1 -->
        <li Class="QuestNode_IsSet">
          <name>asker</name>
          <elseNode Class="QuestNode_GetPawn">
            <storeAs>asker</storeAs>
            <mustBeFactionLeader>true</mustBeFactionLeader>
            <allowPermanentEnemyFaction>false</allowPermanentEnemyFaction>
            <minTechLevel>Industrial</minTechLevel>
          </elseNode>
        </li>

        <li Class="QuestNode_IsSet">
          <name>colonistsToLendCount</name>
          <elseNode Class="QuestNode_Set">
            <n>colonistsToLendCount</n>
            <value>2</value>
          </elseNode>
        </li>

        <li Class="QuestNode_IsSet">
          <name>lendForDays</name>
          <elseNode Class="QuestNode_Set">
            <n>lendForDays</n>
            <value>15</value>
          </elseNode>
        </li>

        <li Class="QuestNode_IsSet">
          <name>dutyDescription</name>
          <elseNode Class="QuestNode_Set">
            <n>dutyDescription</n>
            <value>work</value>
          </elseNode>
        </li>

        <!-- Verify player still has enough colonists -->
        <li Class="QuestNode_GetMap">
          <preferMapWithMinFreeColonists>$colonistsToLendCount</preferMapWithMinFreeColonists>
        </li>

        <li Class="QuestNode_End">
          <inSignal>map.MapRemoved</inSignal>
          <outcome>Fail</outcome>
          <signalListenMode>NotYetAcceptedOnly</signalListenMode>
        </li>

        <!-- BETTER reward: 1.5x the original -->
        <li Class="QuestNode_EvaluateSimpleCurve">
          <value>$($colonistsToLendCount*$lendForDays*1.5)</value>
          <storeAs>rewardValue</storeAs>
          <curve>
            <points>
              <li>5, 400</li>
              <li>50, 1200</li>
              <li>200, 3000</li>
            </points>
          </curve>
        </li>

        <!-- Generate the bonus colonist they're offering -->
        <li Class="QuestNode_GeneratePawn">
          <storeAs>bonusColonist</storeAs>
          <kindDef>Colonist</kindDef>
          <factionOf>$asker</factionOf>
        </li>

        <li Class="QuestNode_ShuttleDelay">
          <delayTicks>3500</delayTicks>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_SubScript">
                <def>Util_TransportShip_Pickup</def>
                <parms>
                  <leaveDelayTicks>60000</leaveDelayTicks>
                  <leaveImmediatelyWhenSatisfied>true</leaveImmediatelyWhenSatisfied>
                  <acceptColonists>true</acceptColonists>
                  <onlyAcceptColonists>true</onlyAcceptColonists>
                  <onlyAcceptHealthy>true</onlyAcceptHealthy>
                  <requireColonistCount>$colonistsToLendCount</requireColonistCount>
                </parms>
              </li>

              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleArrived">Shuttle arrived</label>
                <text TKey="LetterTextShuttleArrived">The shuttle has arrived. [asker_faction_name] is sending [bonusColonist_nameDef] as part of the improved offer.</text>
                <lookTargets>$pickupShipThing</lookTargets>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleDestroyed">Shuttle destroyed</label>
                <text TKey="LetterTextShuttleDestroyed">The shuttle sent to collect colonists has been destroyed.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.LeftBehind</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleDestroyed">Shuttle abandoned</label>
                <text TKey="LetterTextShuttleDestroyed">The shuttle sent to collect colonists has been left behind.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.SentSatisfied</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_LendColonistsToFaction">
                <shuttle>$pickupShipThing</shuttle>
                <lendColonistsToFactionOf>$asker</lendColonistsToFactionOf>
                <returnLentColonistsInTicks>$($lendForDays*60000)</returnLentColonistsInTicks>
                <outSignalComplete>ColonistsReturned</outSignalComplete>
                <outSignalColonistsDied>ColonistsDied</outSignalColonistsDied>
              </li>
              
              <!-- Give reward -->
              <li Class="QuestNode_Delay">
                <delayTicks>$(randInt(300,600))</delayTicks>
                <node Class="QuestNode_GiveRewards">
                  <parms>
                    <allowGoodwill>true</allowGoodwill>
                    <allowRoyalFavor>false</allowRoyalFavor>
                  </parms>
                </node>
              </li>

              <!-- Send bonus colonist -->
              <li Class="QuestNode_Delay">
                <delayTicks>1000</delayTicks>
                <node Class="QuestNode_PawnsArrive">
                  <pawns>$bonusColonist</pawns>
                  <joinPlayer>true</joinPlayer>
                  <arrivalMode>EdgeWalkIn</arrivalMode>
                  <customLetterLabel TKey="LetterLabelBonusColonist">Bonus colonist arrived</customLetterLabel>
                  <customLetterText TKey="LetterTextBonusColonist">[bonusColonist_nameDef] has arrived as part of the contract agreement.</customLetterText>
                </node>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>ColonistsReturned</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelColonistsReturned">Colonists returned</label>
                <text TKey="LetterTextReturnAfterHelping">{PAWNS} [pawnListHaveConjugation] returned after helping [asker_nameFull] of [asker_faction_name] to [dutyDescription].</text>
                <letterDef>PositiveEvent</letterDef>
              </li>
              <li Class="QuestNode_End">
                <outcome>Success</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>ColonistsDied</inSignal>
          <node Class="QuestNode_End">
            <outcome>Success</outcome>
          </node>
        </li>

        <!-- TRIGGER THIRD OFFER WHEN DECLINED AGAIN -->
        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.SentUnsatisfied</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Delay">
                <delayTicks>$(randInt(12,16)*60000)</delayTicks>
                <node Class="QuestNode_GenerateQuest">
                  <questScriptDef>LaborContract_Offer3</questScriptDef>
                  <slate>
                    <asker>$asker</asker>
                    <colonistsToLendCount>$colonistsToLendCount</colonistsToLendCount>
                    <lendForDays>$lendForDays</lendForDays>
                    <dutyDescription>$dutyDescription</dutyDescription>
                  </slate>
                </node>
              </li>
              
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>
        
      </nodes>
    </root>
  </QuestScriptDef>

  <!-- THIRD OFFER: Best deal, final warning -->
  <QuestScriptDef>
    <defName>LaborContract_Offer3</defName>
    <rootSelectionWeight>0</rootSelectionWeight>
    <expireDaysRange>4~8</expireDaysRange>
    
    <questNameRules>
      <rulesStrings>
        <li>questName->Final Offer: [asker_faction_name]</li>
        <li>questName->Last Chance Contract</li>
        <li>questName->Ultimatum from [asker_faction_name]</li>
      </rulesStrings>
    </questNameRules>
    
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->[asker_nameFull] is frustrated but making one final offer.

[asker_pronoun] will pay significantly more silver, send TWO experienced colonists to join you, AND improve relations.

Still needs [colonistsToLendCount] for [lendForDays] days to [dutyDescription].

This is the last time [asker_pronoun] will ask. Refusal will damage your relationship.</li>

        <li>colonistWord(colonistsToLendCount==1)->colonist</li>
        <li>colonistWord(colonistsToLendCount>1)->colonists</li>

        <li>pawnListHaveConjugation(colonistsToLendCount==1)->has</li>
        <li>pawnListHaveConjugation(colonistsToLendCount>1)->have</li>
      </rulesStrings>
    </questDescriptionRules>
    
    <root Class="QuestNode_Sequence">
      <nodes>
        
        <!-- Retrieve values -->
        <li Class="QuestNode_IsSet">
          <name>asker</name>
          <elseNode Class="QuestNode_GetPawn">
            <storeAs>asker</storeAs>
            <mustBeFactionLeader>true</mustBeFactionLeader>
            <allowPermanentEnemyFaction>false</allowPermanentEnemyFaction>
            <minTechLevel>Industrial</minTechLevel>
          </elseNode>
        </li>

        <li Class="QuestNode_IsSet">
          <name>colonistsToLendCount</name>
          <elseNode Class="QuestNode_Set">
            <n>colonistsToLendCount</n>
            <value>2</value>
          </elseNode>
        </li>

        <li Class="QuestNode_IsSet">
          <name>lendForDays</name>
          <elseNode Class="QuestNode_Set">
            <n>lendForDays</n>
            <value>15</value>
          </elseNode>
        </li>

        <li Class="QuestNode_IsSet">
          <name>dutyDescription</name>
          <elseNode Class="QuestNode_Set">
            <n>dutyDescription</n>
            <value>work</value>
          </elseNode>
        </li>

        <li Class="QuestNode_GetMap">
          <preferMapWithMinFreeColonists>$colonistsToLendCount</preferMapWithMinFreeColonists>
        </li>

        <li Class="QuestNode_End">
          <inSignal>map.MapRemoved</inSignal>
          <outcome>Fail</outcome>
          <signalListenMode>NotYetAcceptedOnly</signalListenMode>
        </li>

        <!-- BEST reward: 2x the original -->
        <li Class="QuestNode_EvaluateSimpleCurve">
          <value>$($colonistsToLendCount*$lendForDays*2)</value>
          <storeAs>rewardValue</storeAs>
          <curve>
            <points>
              <li>5, 400</li>
              <li>50, 1200</li>
              <li>200, 3000</li>
            </points>
          </curve>
        </li>

        <!-- Generate TWO bonus colonists -->
        <li Class="QuestNode_GeneratePawn">
          <storeAs>bonusColonist1</storeAs>
          <kindDef>Colonist</kindDef>
          <factionOf>$asker</factionOf>
        </li>

        <li Class="QuestNode_GeneratePawn">
          <storeAs>bonusColonist2</storeAs>
          <kindDef>Colonist</kindDef>
          <factionOf>$asker</factionOf>
        </li>

        <li Class="QuestNode_ShuttleDelay">
          <delayTicks>3500</delayTicks>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_SubScript">
                <def>Util_TransportShip_Pickup</def>
                <parms>
                  <leaveDelayTicks>60000</leaveDelayTicks>
                  <leaveImmediatelyWhenSatisfied>true</leaveImmediatelyWhenSatisfied>
                  <acceptColonists>true</acceptColonists>
                  <onlyAcceptColonists>true</onlyAcceptColonists>
                  <onlyAcceptHealthy>true</onlyAcceptHealthy>
                  <requireColonistCount>$colonistsToLendCount</requireColonistCount>
                </parms>
              </li>

              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleArrived">Final offer shuttle arrived</label>
                <text TKey="LetterTextShuttleArrived">The shuttle has arrived for the final contract offer.</text>
                <lookTargets>$pickupShipThing</lookTargets>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleDestroyed">Shuttle destroyed</label>
                <text TKey="LetterTextShuttleDestroyed">The shuttle sent to collect colonists has been destroyed.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.LeftBehind</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelShuttleDestroyed">Shuttle abandoned</label>
                <text TKey="LetterTextShuttleDestroyed">The shuttle sent to collect colonists has been left behind.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.SentSatisfied</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_LendColonistsToFaction">
                <shuttle>$pickupShipThing</shuttle>
                <lendColonistsToFactionOf>$asker</lendColonistsToFactionOf>
                <returnLentColonistsInTicks>$($lendForDays*60000)</returnLentColonistsInTicks>
                <outSignalComplete>ColonistsReturned</outSignalComplete>
                <outSignalColonistsDied>ColonistsDied</outSignalColonistsDied>
              </li>
              
              <!-- Give reward -->
              <li Class="QuestNode_Delay">
                <delayTicks>$(randInt(300,600))</delayTicks>
                <node Class="QuestNode_GiveRewards">
                  <parms>
                    <allowGoodwill>true</allowGoodwill>
                    <allowRoyalFavor>false</allowRoyalFavor>
                  </parms>
                </node>
              </li>

              <!-- Send BOTH bonus colonists -->
              <li Class="QuestNode_Delay">
                <delayTicks>1000</delayTicks>
                <node Class="QuestNode_PawnsArrive">
                  <pawns>$bonusColonist1</pawns>
                  <joinPlayer>true</joinPlayer>
                  <arrivalMode>EdgeWalkIn</arrivalMode>
                </node>
              </li>

              <li Class="QuestNode_Delay">
                <delayTicks>2000</delayTicks>
                <node Class="QuestNode_PawnsArrive">
                  <pawns>$bonusColonist2</pawns>
                  <joinPlayer>true</joinPlayer>
                  <arrivalMode>EdgeWalkIn</arrivalMode>
                  <customLetterLabel TKey="LetterLabelBonusColonists">Bonus colonists arrived</customLetterLabel>
                  <customLetterText TKey="LetterTextBonusColonists">[bonusColonist1_nameDef] and [bonusColonist2_nameDef] have arrived as part of the final contract offer.</customLetterText>
                </node>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>ColonistsReturned</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelColonistsReturned">Colonists returned</label>
                <text TKey="LetterTextReturnAfterHelping">{PAWNS} [pawnListHaveConjugation] returned after helping [asker_nameFull] of [asker_faction_name] to [dutyDescription].</text>
                <letterDef>PositiveEvent</letterDef>
              </li>
              <li Class="QuestNode_End">
                <outcome>Success</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>ColonistsDied</inSignal>
          <node Class="QuestNode_End">
            <outcome>Success</outcome>
          </node>
        </li>

        <!-- CONSEQUENCE: Decline third time = goodwill loss -->
        <li Class="QuestNode_Signal">
          <inSignal>pickupShipThing.SentUnsatisfied</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <!-- Lose goodwill with faction -->
              <li Class="QuestNode_GiveFactionGoodwill">
                <change>-15</change>
                <factionOf>$asker</factionOf>
              </li>
              
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelContractRefused">Contract refused</label>
                <text TKey="LetterTextContractRefused">[asker_faction_name] is offended by your repeated refusals. Relations have worsened.</text>
                <letterDef>NegativeEvent</letterDef>
              </li>
              
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>
        
      </nodes>
    </root>
  </QuestScriptDef>

</Defs>