<?xml version='1.0' encoding='utf-8'?>
<Defs>
	<FactionDef ParentName="FactionBase">
		<defName>EOTF_Rough</defName>
		<label>dominion freelancers</label>
		<description>New arrivals to this world from the Dominion, bringing their technology from their empire. They use spacer-level technology and advanced armor and weapons in their pursuit of profit. Their sole concern seems to be finding new avenues of profit on this world.\n\nThey are concerned with their bottom line and maintaining of order. Though happy to trade, they view you as their next business venture.</description>
		<pawnSingular>citizen</pawnSingular>
		<pawnsPlural>citizens</pawnsPlural>
		<listOrderPriority>13</listOrderPriority>
		<settlementGenerationWeight>1</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxCountAtGameStart>1</maxCountAtGameStart>
		<canMakeRandomly>true</canMakeRandomly>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<leaderTitle>commander</leaderTitle>
		<factionIconPath>UI/FactionIcons/DominionRoughOutpost</factionIconPath>
		<factionNameMaker>EOTF_Faction_Rough</factionNameMaker>
		<settlementNameMaker>EOTF_Settlement_Rough</settlementNameMaker>
		<colorSpectrum>
			<li>(0.60, 0.15, 0.15)</li>
		</colorSpectrum>
		<permanentEnemy>true</permanentEnemy>
		<techLevel>Spacer</techLevel>
		<allowedCultures>
			<li>Astropolitan</li>
		</allowedCultures>
		<requiredMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Individualist</li>			
			<li MayRequire="Ludeon.RimWorld.Ideology">Raider</li>
		</requiredMemes>
		<disallowedMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Collectivist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">TreeConnection</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">AnimalPersonhood</li>
		</disallowedMemes>
		<backstoryFilters>
			<li>
				<categories>
					<li>Outlander</li>
					<li>Pirate</li>
				</categories>
			</li>
		</backstoryFilters>
		<xenotypeSet>
			<xenotypeChances>
				<Starjack MayRequire="Ludeon.RimWorld.Odyssey">0.12</Starjack>
				<Hussar MayRequire="Ludeon.RimWorld.Biotech">0.04</Hussar>
				<Pigskin MayRequire="Ludeon.RimWorld.Biotech">0.08</Pigskin>
				<Impid MayRequire="Ludeon.RimWorld.Biotech">0.08</Impid>
				<Waster MayRequire="Ludeon.RimWorld.Biotech">0.06</Waster>
				<Sanguophage MayRequire="Ludeon.RimWorld.Biotech">0.01</Sanguophage>
			</xenotypeChances>
		</xenotypeSet>
		<allowedArrivalTemperatureRange>-40~50</allowedArrivalTemperatureRange>
		<raidLootMaker>OutlanderRaidLootMaker</raidLootMaker>
		<caravanTraderKinds>
			<li>Caravan_Dominion_BulkGoods</li>
			<li>Caravan_Dominion_ArmsDealer</li>
			<li>Caravan_Dominion_Exotic</li>
		</caravanTraderKinds>
		<visitorTraderKinds>
			<li>Visitor_Dominion_Standard</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>Base_Dominion_Standard</li>
		</baseTraderKinds>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0, 40)</li>
				<li>(70, 60)</li>
				<li>(700, 120)</li>
				<li>(1300, 200)</li>
				<li>(100000,10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		<pawnGroupMakers>
			<!-- Combat Group 1: Mixed forces with ranged and melee -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>45</commonality>
				<options>
					<EOTF_Rough_Recruit_Ranged>5</EOTF_Rough_Recruit_Ranged>
					<EOTF_Rough_Recruit_Melee>3</EOTF_Rough_Recruit_Melee>
					<EOTF_Rough_Infantry_Ranged>12</EOTF_Rough_Infantry_Ranged>
					<EOTF_Rough_Infantry_Melee>6</EOTF_Rough_Infantry_Melee>
					<EOTF_Rough_Veteran_Ranged>8</EOTF_Rough_Veteran_Ranged>
					<EOTF_Rough_Veteran_Melee>5</EOTF_Rough_Veteran_Melee>
					<EOTF_Rough_Sergeant>4</EOTF_Rough_Sergeant>
					<EOTF_Rough_Ranger>7</EOTF_Rough_Ranger>
					<EOTF_Rough_Grenadier>3</EOTF_Rough_Grenadier>
					<EOTF_Rough_Shocktrooper>2</EOTF_Rough_Shocktrooper>
					<EOTF_Rough_Medic>3</EOTF_Rough_Medic>
					<EOTF_Rough_Engineer>3</EOTF_Rough_Engineer>
					<EOTF_Rough_Warden>2</EOTF_Rough_Warden>
					<EOTF_Rough_Officer>3</EOTF_Rough_Officer>
				</options>
			</li>

			<!-- Combat Group 2: Standard raid composition -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>35</commonality>
				<options>
					<EOTF_Rough_Recruit_Ranged>8</EOTF_Rough_Recruit_Ranged>
					<EOTF_Rough_Recruit_Melee>5</EOTF_Rough_Recruit_Melee>
					<EOTF_Rough_Infantry_Ranged>20</EOTF_Rough_Infantry_Ranged>
					<EOTF_Rough_Infantry_Melee>10</EOTF_Rough_Infantry_Melee>
					<EOTF_Rough_Sergeant>5</EOTF_Rough_Sergeant>
					<EOTF_Rough_Medic>8</EOTF_Rough_Medic>
					<EOTF_Rough_Engineer>8</EOTF_Rough_Engineer>
					<EOTF_Rough_Officer>3</EOTF_Rough_Officer>
				</options>
			</li>

			<!-- Peaceful Group -->
			<li>
				<kindDef>Peaceful</kindDef>
				<commonality>20</commonality>
				<options>
					<EOTF_Rough_Settler>12</EOTF_Rough_Settler>
					<EOTF_Rough_Laborer>8</EOTF_Rough_Laborer>
					<EOTF_Rough_Trader>8</EOTF_Rough_Trader>
					<EOTF_Rough_Representative>2</EOTF_Rough_Representative>
					<EOTF_Rough_Ranger>4</EOTF_Rough_Ranger>
					<EOTF_Rough_Infantry_Ranged>4</EOTF_Rough_Infantry_Ranged>
					<EOTF_Rough_Infantry_Melee>2</EOTF_Rough_Infantry_Melee>
					<EOTF_Rough_Medic>2</EOTF_Rough_Medic>
					<EOTF_Rough_Engineer>2</EOTF_Rough_Engineer>
					<EOTF_Rough_Officer>1</EOTF_Rough_Officer>
				</options>
			</li>

			<!-- Trader Group -->
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<EOTF_Rough_Trader>1</EOTF_Rough_Trader>
				</traders>
				<carriers>
					<Muffalo>8</Muffalo>
				</carriers>
				<guards>
					<EOTF_Rough_Infantry_Ranged>4</EOTF_Rough_Infantry_Ranged>
					<EOTF_Rough_Infantry_Melee>2</EOTF_Rough_Infantry_Melee>
					<EOTF_Rough_Ranger>4</EOTF_Rough_Ranger>
					<EOTF_Rough_Sergeant>2</EOTF_Rough_Sergeant>
					<EOTF_Rough_Officer>1</EOTF_Rough_Officer>
				</guards>
			</li>

			<!-- Settlement Group -->
			<li>
				<kindDef>Settlement</kindDef>
				<options>
					<EOTF_Rough_Settler>20</EOTF_Rough_Settler>
					<EOTF_Rough_Laborer>12</EOTF_Rough_Laborer>
					<EOTF_Rough_Engineer>4</EOTF_Rough_Engineer>
					<EOTF_Rough_Medic>4</EOTF_Rough_Medic>
					<EOTF_Rough_Infantry_Ranged>6</EOTF_Rough_Infantry_Ranged>
					<EOTF_Rough_Infantry_Melee>2</EOTF_Rough_Infantry_Melee>
					<EOTF_Rough_Ranger>6</EOTF_Rough_Ranger>
					<EOTF_Rough_Representative>1</EOTF_Rough_Representative>
					<EOTF_Rough_Officer>3</EOTF_Rough_Officer>
				</options>
			</li>
		</pawnGroupMakers>
		<settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
		<maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>25</configurationListOrderPriority>
	</FactionDef>

</Defs>
