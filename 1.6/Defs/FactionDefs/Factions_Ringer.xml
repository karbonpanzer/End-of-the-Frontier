<?xml version='1.0' encoding='utf-8'?>
<Defs>

	<!-- Refugees - Player Faction-->

	<FactionDef ParentName="PlayerFactionBase">
		<defName>TRG_Player</defName>
		<label>Ringer settlers</label>
		<description>A group of Ringers who left their ring city for the rimworld. They came prepared.</description>
		<colorSpectrum>
            <li>(0, 0.737, 0.847)</li>
		</colorSpectrum>
		<isPlayer>true</isPlayer>
		<basicMemberKind>TRG_Player</basicMemberKind>
		<pawnSingular>ringer</pawnSingular>
		<pawnsPlural>ringers</pawnsPlural>
		<techLevel>Spacer</techLevel>
		<allowedCultures>
			<li>Astropolitan</li>
		</allowedCultures>
		<factionNameMaker>TRG_Faction_Civil</factionNameMaker>
		<settlementNameMaker>TRG_Settlement_Civil</settlementNameMaker>
		<backstoryFilters>
		  <li>
			<categories>
				<li>Outlander</li>
			</categories>
		  </li>
		</backstoryFilters>
		<apparelStuffFilter>
			<thingDefs>
				<li>Synthread</li>
			</thingDefs>
		</apparelStuffFilter>
		<factionIconPath>UI/FactionIcons/DominionPlayerHome</factionIconPath>
		<startingResearchTags>
			<li>ClassicStart</li>
		</startingResearchTags>
		<startingTechprintsResearchTags>
			<li>ClassicStart</li>
			<li>ClassicStartTechprints</li>
		</startingTechprintsResearchTags>
	</FactionDef>

	<!-- Colonists - Civil Faction-->

	<FactionDef ParentName="FactionBase">
		<defName>TRG_Civil</defName>
		<label>Ringer settlers</label>
		<description>Settlers from a ring city who have established themselves on this world. They carry spacer-level equipment and the habits of people raised in an enclosed habitat. They trade, patrol their borders, and defend their settlements without hesitation.</description>
		<pawnSingular>ringer</pawnSingular>
		<pawnsPlural>ringers</pawnsPlural>
		<listOrderPriority>13</listOrderPriority>
		<settlementGenerationWeight>1</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxCountAtGameStart>1</maxCountAtGameStart>
		<canMakeRandomly>true</canMakeRandomly>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<leaderTitle>governor</leaderTitle>
		<factionIconPath>UI/FactionIcons/Dominion</factionIconPath>
		<factionNameMaker>TRG_Faction_Civil</factionNameMaker>
		<settlementNameMaker>TRG_Settlement_Civil</settlementNameMaker>
		<colorSpectrum>
			<li>(0.80, 0.80, 0.95)</li>
		</colorSpectrum>
		<permanentEnemy>false</permanentEnemy>
		<techLevel>Spacer</techLevel>
		<allowedCultures>
			<li>Astropolitan</li>
		</allowedCultures>
		<requiredMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Individualist</li>			
		</requiredMemes>
		<disallowedMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Raider</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Supremacist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Cannibal</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">TreeConnection</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">AnimalPersonhood</li>
		</disallowedMemes>
		<backstoryFilters>
			<li>
				<categories>
					<li>Outlander</li>
					<li>Pirate</li>
				</categories>
			</li>
		</backstoryFilters>
		<xenotypeSet>
			<xenotypeChances>
				<Hussar MayRequire="Ludeon.RimWorld.Biotech">0.12</Hussar>
				<Dirtmole MayRequire="Ludeon.RimWorld.Biotech">0.06</Dirtmole>
				<Impid MayRequire="Ludeon.RimWorld.Biotech">0.02</Impid>
				<Genie MayRequire="Ludeon.RimWorld.Biotech">0.08</Genie>
				<Yttakin MayRequire="Ludeon.RimWorld.Biotech">0.02</Yttakin>
			</xenotypeChances>
		</xenotypeSet>
		<allowedArrivalTemperatureRange>-40~50</allowedArrivalTemperatureRange>
		<raidLootMaker>OutlanderRaidLootMaker</raidLootMaker>
		<caravanTraderKinds>
			<li>Caravan_Ringer_BulkGoods</li>
			<li>Caravan_Ringer_ArmsDealer</li>
			<li>Caravan_Ringer_Exotic</li>
		</caravanTraderKinds>
		<visitorTraderKinds>
			<li>Visitor_Ringer_Standard</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>Base_Ringer_Standard</li>
		</baseTraderKinds>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0, 40)</li>
				<li>(70, 60)</li>
				<li>(700, 120)</li>
				<li>(1300, 200)</li>
				<li>(100000,10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		<pawnGroupMakers>
			<!-- Combat Group 1: Mixed forces with ranged and melee -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>45</commonality>
				<options>
					<TRG_Civil_Recruit_Ranged>5</TRG_Civil_Recruit_Ranged>
					<TRG_Civil_Recruit_Melee>3</TRG_Civil_Recruit_Melee>
					<TRG_Civil_Infantry_Ranged>12</TRG_Civil_Infantry_Ranged>
					<TRG_Civil_Infantry_Melee>6</TRG_Civil_Infantry_Melee>
					<TRG_Civil_Veteran_Ranged>8</TRG_Civil_Veteran_Ranged>
					<TRG_Civil_Veteran_Melee>5</TRG_Civil_Veteran_Melee>
					<TRG_Civil_Sergeant>4</TRG_Civil_Sergeant>
					<TRG_Civil_Ranger>7</TRG_Civil_Ranger>
					<TRG_Civil_GrenadierFrag>3</TRG_Civil_GrenadierFrag>
					<TRG_Civil_GrenadierEMP>3</TRG_Civil_GrenadierEMP>
					<TRG_Civil_GrenadierFire>3</TRG_Civil_GrenadierFire>
					<TRG_Civil_GrenadierFire MayRequire="Ludeon.RimWorld.Biotech">3</TRG_Civil_GrenadierFire>
					<TRG_Civil_Shocktrooper>2</TRG_Civil_Shocktrooper>
					<TRG_Civil_Medic>3</TRG_Civil_Medic>
					<TRG_Civil_Engineer>3</TRG_Civil_Engineer>
					<TRG_Civil_Warden>2</TRG_Civil_Warden>
					<TRG_Civil_Officer>3</TRG_Civil_Officer>
				</options>
			</li>

			<!-- Combat Group 2: Standard raid composition -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>35</commonality>
				<options>
					<TRG_Civil_Recruit_Ranged>8</TRG_Civil_Recruit_Ranged>
					<TRG_Civil_Recruit_Melee>5</TRG_Civil_Recruit_Melee>
					<TRG_Civil_Infantry_Ranged>20</TRG_Civil_Infantry_Ranged>
					<TRG_Civil_Infantry_Melee>10</TRG_Civil_Infantry_Melee>
					<TRG_Civil_Sergeant>5</TRG_Civil_Sergeant>
					<TRG_Civil_Medic>8</TRG_Civil_Medic>
					<TRG_Civil_Engineer>8</TRG_Civil_Engineer>
					<TRG_Civil_Officer>3</TRG_Civil_Officer>
				</options>
			</li>

			<!-- Peaceful Group -->
			<li>
				<kindDef>Peaceful</kindDef>
				<commonality>20</commonality>
				<options>
					<TRG_Civil_Settler>12</TRG_Civil_Settler>
					<TRG_Civil_Laborer>8</TRG_Civil_Laborer>
					<TRG_Civil_Trader>8</TRG_Civil_Trader>
					<TRG_Civil_Representative>2</TRG_Civil_Representative>
					<TRG_Civil_Ranger>4</TRG_Civil_Ranger>
					<TRG_Civil_Infantry_Ranged>4</TRG_Civil_Infantry_Ranged>
					<TRG_Civil_Infantry_Melee>2</TRG_Civil_Infantry_Melee>
					<TRG_Civil_Medic>2</TRG_Civil_Medic>
					<TRG_Civil_Engineer>2</TRG_Civil_Engineer>
					<TRG_Civil_Officer>1</TRG_Civil_Officer>
				</options>
			</li>

			<!-- Trader Group -->
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<TRG_Civil_Trader>1</TRG_Civil_Trader>
				</traders>
				<carriers>
					<Muffalo>6</Muffalo>
					<Dromedary>5</Dromedary>
					<Alpaca>2</Alpaca>
					<Elephant>1</Elephant>
				</carriers>
				<guards>
					<TRG_Civil_Infantry_Ranged>4</TRG_Civil_Infantry_Ranged>
					<TRG_Civil_Infantry_Melee>2</TRG_Civil_Infantry_Melee>
					<TRG_Civil_Ranger>4</TRG_Civil_Ranger>
					<TRG_Civil_Sergeant>2</TRG_Civil_Sergeant>
					<TRG_Civil_Officer>1</TRG_Civil_Officer>
				</guards>
			</li>

			<!-- Settlement Group -->
			<li>
				<kindDef>Settlement</kindDef>
				<options>
					<TRG_Civil_Settler>20</TRG_Civil_Settler>
					<TRG_Civil_Laborer>12</TRG_Civil_Laborer>
					<TRG_Civil_Engineer>4</TRG_Civil_Engineer>
					<TRG_Civil_Medic>4</TRG_Civil_Medic>
					<TRG_Civil_Infantry_Ranged>6</TRG_Civil_Infantry_Ranged>
					<TRG_Civil_Infantry_Melee>2</TRG_Civil_Infantry_Melee>
					<TRG_Civil_Ranger>6</TRG_Civil_Ranger>
					<TRG_Civil_Representative>1</TRG_Civil_Representative>
					<TRG_Civil_Officer>3</TRG_Civil_Officer>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Miners</kindDef>
				<commonality>1</commonality>
				<options>
					<Miner>1</Miner>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Hunters</kindDef>
				<commonality>1</commonality>
				<options>
					<Hunter>1</Hunter>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Loggers</kindDef>
				<commonality>1</commonality>
				<options>
					<Logger>1</Logger>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Farmers</kindDef>
				<commonality>1</commonality>
				<options>
					<Farmer>1</Farmer>
				</options>
			</li>			
		</pawnGroupMakers>
		<settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
		<maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>25</configurationListOrderPriority>
	</FactionDef>	

	<!-- Freelancers - Hostile Faction-->

