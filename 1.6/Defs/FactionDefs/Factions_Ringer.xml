		</caravanTraderKinds>
		<visitorTraderKinds>
			<li>Visitor_Ringer_Standard</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>Base_Ringer_Standard</li>
		</baseTraderKinds>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0, 40)</li>
				<li>(70, 60)</li>
				<li>(700, 120)</li>
				<li>(1300, 200)</li>
