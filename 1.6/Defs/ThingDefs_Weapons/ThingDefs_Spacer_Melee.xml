<Defs>

	<!-- ==================== VIBROSWORD ==================== -->

	<ThingDef ParentName="BaseMeleeWeapon_Sharp_Quality">
		<defName>EOTF_Vibrosword</defName>
		<label>Vibrosword</label>
		<description>A composite sword powered by a small micro-motor which vibrates the blade. Easily able to carve through armor and flesh, the production of it is a closely guarded secret in the Dominion.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Item/Equipment/WeaponMelee/chainsword</texPath>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.4</drawSize>
		</graphicData>
		<techLevel>Spacer</techLevel>
		<uiIconScale>0.9</uiIconScale>
		<equippedAngleOffset>-50</equippedAngleOffset>
		<recipeMaker>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<researchPrerequisite>EOTF_VibroWeapons</researchPrerequisite>
			<skillRequirements>
				<Crafting>10</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>TableMachining</li>
			</recipeUsers>
		</recipeMaker>
		<costStuffCount>40</costStuffCount>
		<costList>
			<ComponentIndustrial>3</ComponentIndustrial>
			<ComponentSpacer>3</ComponentSpacer>
			<Plasteel>30</Plasteel>
		</costList>
		<statBases>
			<WorkToMake>36000</WorkToMake>
			<Mass>1.6</Mass>
			<MarketValue>3600</MarketValue>
		</statBases>
		<stuffCategories>
			<li>Metallic</li>
		</stuffCategories>
		<tools>
			<li>
				<label>handle</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2.1</cooldownTime>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>26</power>
				<cooldownTime>2.1</cooldownTime>
				<armorPenetration>0.50</armorPenetration>
			</li>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>24</power>
				<cooldownTime>2.1</cooldownTime>
