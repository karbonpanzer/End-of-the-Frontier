			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>26</power>
				<cooldownTime>2.1</cooldownTime>
				<armorPenetration>0.50</armorPenetration>
			</li>
			<li>
				<label>point</label>
