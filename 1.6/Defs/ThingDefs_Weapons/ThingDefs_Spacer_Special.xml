<?xml version='1.0' encoding='UTF-8'?>
<Defs>

	<!-- ==================== GAUSS RIFLE ==================== -->

	<ThingDef ParentName="BaseBullet">
		<defName>EOTF_Round_GaussRifle</defName>
		<label>gauss rifle ferrous slug</label>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Projectile/Chemrail_Round</texPath>
			<drawSize>0.7</drawSize>
		</graphicData>
		<projectile>
			<flyOverhead>false</flyOverhead>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>40</damageAmountBase>
			<armorPenetrationBase>0.76</armorPenetrationBase>
			<speed>115</speed>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseHumanMakeableGun">
		<defName>EOTF_GaussRifle</defName>
		<label>Gauss Rifle</label>
		<description>A rifle converted into a gauss rifle using a modified foregrip. Rather than full adopt a new weapon, using a series of magnetic coils it turns a simple firearm into a powerful rifle cheaply.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Item/Equipment/WeaponRanged/chemrailrifle</texPath>
			<drawSize>1.3</drawSize>
		</graphicData>
		<techLevel>Spacer</techLevel>
		<soundInteract>Interact_Rifle</soundInteract>
		<recipeMaker>
			<researchPrerequisite>EOTF_AdvancedWeaponry</researchPrerequisite>
			<skillRequirements>
				<Crafting>9</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>TableMachining</li>
			</recipeUsers>
		</recipeMaker>
		<costList>
			<Steel>80</Steel>
			<ComponentIndustrial>6</ComponentIndustrial>
			<ComponentSpacer>4</ComponentSpacer>
			<Plasteel>20</Plasteel>
		</costList>
		<statBases>
			<WorkToMake>56000</WorkToMake>
			<Mass>7.5</Mass>
			<MarketValue>4600</MarketValue>
			<AccuracyTouch>0.35</AccuracyTouch>
			<AccuracyShort>0.55</AccuracyShort>
			<AccuracyMedium>0.80</AccuracyMedium>
			<AccuracyLong>0.90</AccuracyLong>
			<RangedWeapon_Cooldown>3.0</RangedWeapon_Cooldown>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.20</MoveSpeed>
		</equippedStatOffsets>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>EOTF_Round_GaussRifle</defaultProjectile>
				<warmupTime>2.8</warmupTime>
				<burstShotCount>2</burstShotCount>
				<range>45.0</range>
				<soundCast>ChargeLance_Fire</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>10</muzzleFlashScale>
			</li>
		</verbs>
		<weaponTags>
			<li>SpacerGun</li>
			<li>ChargeRifle</li>
			<li>SniperRifle</li>
			<li>BNF_Ranger</li>
			<li>BNF_Commander</li>
		</weaponTags>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>14</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<thingSetMakerTags>
			<li>RewardStandardHighTech</li>
		</thingSetMakerTags>
		<tradeTags>
			<li>WeaponRanged</li>
		</tradeTags>
	</ThingDef>

