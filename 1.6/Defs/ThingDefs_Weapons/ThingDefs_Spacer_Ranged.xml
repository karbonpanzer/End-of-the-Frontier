			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Item/Equipment/WeaponRanged/assaultpistol</texPath>
			<drawSize>0.9</drawSize>
		</graphicData>
		<techLevel>Spacer</techLevel>
		<soundInteract>Interact_Revolver</soundInteract>
		<recipeMaker>
			<researchPrerequisite>EOTF_MercenaryWeaponry</researchPrerequisite>
			<skillRequirements>
				<Crafting>8</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>EOTF_DominionFabricator</li>
			</recipeUsers>
		</recipeMaker>
		<costList>
			<Steel>30</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
			<ComponentSpacer>2</ComponentSpacer>
			<Plasteel>10</Plasteel>
		</costList>
