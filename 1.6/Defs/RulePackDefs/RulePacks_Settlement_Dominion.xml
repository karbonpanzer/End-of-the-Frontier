<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <RulePackDef>
    <defName>EOTF_Settlement_Exile</defName>
    <rulePack>
      <rulesStrings>
        <li>r_name(p=12)->[townname_wordgen]</li>
        <li>r_name(p=6)->[townname_fixed]</li>
        <li>r_name(p=4)->[townname_combo]</li>
        <li>r_name->[townname_near]</li>
        <li>r_name->[exile_prefix_mil] [cityname_fixed]</li>
        <li>r_name->[exile_prefix_mil] [townname_wordgen]</li>
        <li>r_name->[exile_prefix_mil] [townname_fixed]</li>

        <!-- Military legacy settlement patterns -->
        <li>r_name->[townname_wordgen] [mil_suffix]</li>
        <li>r_name->[townname_fixed] [mil_suffix]</li>
        <li>r_name->[exile_prefix_mil] [mil_suffix]</li>

        <!-- Warrior-turned-settler patterns -->
        <li>r_name->[exile_concept] [mil_suffix]</li>
        <li>r_name->[exile_prefix_civ] [exile_concept]</li>

        <!-- Combo patterns -->
        <li>townname_combo->[topicalnoun] [TerrainFeature]</li>
        <li>townname_combo->[topicalnoun] [mil_suffix]</li>
        <li>townname_combo->[topicalnoun]'s [TerrainFeature]</li>
        <li>townname_combo->[topicalnoun]'s [mil_suffix]</li>
        <li>townname_combo(p=2)->[exile_concept]'s [TerrainFeature]</li>
        <li>townname_combo(p=2)->[exile_concept] [TerrainFeature]</li>
        <li>townname_combo(p=2)->[exile_concept] [mil_suffix]</li>
        <li>townname_combo(p=3)->[Character]'s [TerrainFeature]</li>
        <li>townname_combo(p=3)->[Character]'s [mil_suffix]</li>
        <li>townname_combo(p=3)->[Character]'s Rest</li>
        <li>townname_combo(p=3)->[Character]'s Landing</li>

        <!-- Near patterns -->
        <li>townname_near->[nearnameinitial]-at-the-[TerrainFeature]</li>
        <li>townname_near->[nearnameinitial]-by-the-[TerrainFeature]</li>
        <li>townname_near->[nearnameinitial]-on-the-[TerrainFeature]</li>
        <li>nearnameinitial->[townname_wordgen]</li>
        <li>nearnameinitial->[Community]</li>

        <!-- Wordgen -->
        <li>townname_wordgen(p=2)->[SylE][SylE]</li>
        <li>townname_wordgen(p=2)->[SylE][SylE][SylE]</li>
        <li>townname_wordgen(p=2)->[SylE][townend]</li>
        <li>townname_wordgen(p=2)->[SylE][SylE][townend]</li>
        <li>townname_wordgen->[TerrainFeature][townend]</li>
        <li>townname_wordgen->[topicalnoun][townend]</li>

        <li>townend->ville</li>
        <li>townend->town</li>
        <li>townend->hurst</li>
        <li>townend->bourne</li>
        <li>townend->brad</li>
        <li>townend->dale</li>
        <li>townend->hope</li>
        <li>townend->ing</li>
        <li>townend->ness</li>
        <li>townend->mere</li>
        <li>townend->shaw</li>
        <li>townend->wick</li>
        <li>townend->ton</li>
        <li>townend->ston</li>
        <li>townend->os</li>
        <li>townend->den</li>
        <li>townend->tas</li>
        <li>townend->wood</li>
        <li>townend->land</li>
        <li>townend->worth</li>
        <li>townend->roon</li>
        <li>townend->ron</li>
        <li>townend->well</li>
      </rulesStrings>
      <rulesFiles>
        <li>cityname_fixed->Names/CityNames</li>
        <li>townname_fixed->Names/ExpeditionTowns</li>
        <li>exile_prefix_mil->Words/Adjectives/SettlementPrefix_ExileMil</li>
        <li>exile_prefix_civ->Words/Adjectives/SettlementPrefix_ExileCiv</li>
        <li>mil_suffix->Words/Nouns/MilitarySuffix_Exile</li>
        <li>exile_concept->Words/Nouns/Concepts_Exile</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>

  <RulePackDef>
    <defName>EOTF_Settlement_Rough</defName>
    <rulePack>
      <rulesStrings>

        <li>r_name->[townname_combo]</li>
        <li>r_name->[townname_wordgen]</li>

        <li>townname_combo->[AnimalBadass] [geography]</li>
        <li>townname_combo->[AnimalBadass]'s [geography]</li>
        <li>townname_combo->[ConceptBadass] [geography]</li>
        <li>townname_combo->[ConceptBadass]'s [geography]</li>
        <li>townname_combo->[PersonBadass] [geography]</li>
        <li>townname_combo->[PersonBadass]'s [geography]</li>
