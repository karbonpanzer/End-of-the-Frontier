        <li>townendevil->vash</li>
        <li>townendevil->warg</li>
        <li>townendevil->wug</li>
        <li>townendevil->thot</li>
        <li>townendevil->thard</li>
        <li>townendevil->thad</li>

      </rulesStrings>
      <rulesFiles>
        <li>inventor->Words/Nouns/PlaceInventor_Dominion</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>  
</Defs>
