<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Dominion pawn name utility -->
  <RulePackDef>
    <defName>EOTF_PawnNamerDominion</defName>
    <rulePack>
      <rulesFiles>
        <li>EOTF_FirstM->Names/Dominion_FirstM</li>
        <li>EOTF_FirstF->Names/Dominion_FirstF</li>
        <li>EOTF_Last->Names/Dominion_Last</li>
      </rulesFiles>
      <rulesStrings>
        <li>EOTF_Dominion_FirstM->[EOTF_FirstM]</li>
        <li>EOTF_Dominion_FirstF->[EOTF_FirstF]</li>
        <li>EOTF_Dominion_Last->[EOTF_Last]</li>
      </rulesStrings>
    </rulePack>
  </RulePackDef>

  <!-- Male Dominion pawn name generator -->
  <RulePackDef>
    <defName>EOTF_NamerPerson_DominionMale</defName>
    <include>
      <li>EOTF_PawnNamerDominion</li>
    </include>
    <rulePack>
      <rulesStrings>
        <li>r_name(p=2)->[EOTF_Dominion_FirstM] [EOTF_Dominion_Last]</li>
      </rulesStrings>
    </rulePack>
  </RulePackDef>

  <!-- Female Dominion pawn name generator -->
  <RulePackDef>
    <defName>EOTF_NamerPerson_DominionFemale</defName>
    <include>
      <li>EOTF_PawnNamerDominion</li>
    </include>
    <rulePack>
      <rulesStrings>
        <li>r_name(p=2)->[EOTF_Dominion_FirstF] [EOTF_Dominion_Last]</li>
      </rulesStrings>
    </rulePack>
  </RulePackDef>

</Defs>