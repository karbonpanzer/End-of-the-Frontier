  <RulePackDef>
    <defName>EOTF_Faction_Civil</defName>
    <include>
      <li>OutlanderPlaceNameUtility</li>
    </include>
    <rulePack>
      <rulesStrings>
        <li>r_name->[nearnameinitial] [political_union_exile]</li>
        <li>r_name->[nearnameinitial] [political_adjective_exile] [political_union_exile]</li>
        <li>r_name->[political_union_exile] of [nearnameinitial]</li>
        <li>r_name->[political_adjective_exile] [political_union_exile] of [nearnameinitial]</li>
        <li>r_name->[political_adjective_exile] [political_union_civic] of [nearnameinitial]</li>
        <li>r_name->[nearnameinitial] [political_union_civic]</li>
        <li>r_name->[political_union_civic] of [nearnameinitial]</li>

        <li>nearnameinitial(p=3)->[PlaceOutlander]</li>
        <li>nearnameinitial->[Direction] [PlaceOutlander]</li>
      </rulesStrings>
      <rulesFiles>
        <li>political_union_exile->Words/Nouns/PoliticalUnions_Exile</li>
        <li>political_union_civic->Words/Nouns/PoliticalUnions_ExileCivic</li>
        <li>political_adjective_exile->Words/Adjectives/Political_Adjective_Exile</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>


