  <!-- CIVIL PLayer NAMER -->

  <RulePackDef>
    <defName>EOTF_Faction_Player</defName>
    <rulePack>
      <rulesStrings>

        <!-- [adjective] [colony noun] -->
        <li>r_name->The [colony_adjective] [colony_noun]</li>
        <li>r_name->[colony_adjective] [colony_noun]</li>

        <!-- [adjective] [colony noun] of [place] -->
