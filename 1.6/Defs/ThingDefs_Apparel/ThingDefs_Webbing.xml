<Defs>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>TMG_Webbing_Infantry</defName>
    <label>Infantry Webbing</label>
    <description>A standard load-bearing harness worn by Meridia infantry. Distributes the weight of ammunition and field kit across the torso. Issued to most front-line personnel.</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Accessories/InfantryPouches/InfantryPouches</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.50,0.5,0.36)</only>
        </li>
        <li>
          <weight>6</weight>
          <only>(0.40,0.57,0.40)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.38,0.36,0.20)</only>
        </li>
        <li>
          <weight>10</weight>
