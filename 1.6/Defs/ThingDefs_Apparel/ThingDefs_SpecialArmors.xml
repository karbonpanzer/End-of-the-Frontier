<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ArmorMachineableBase">
    <defName>EOTF_OfficerCarapaceArmor</defName>
    <label>Officer Carapace Armor</label>
    <description>A carapace armor set finished for officer-grade wear. Offers equivalent protection to standard carapace while maintaining the appearance expected of command personnel.</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Armor/OfficerArmor/OfficerArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>EOTF_OfficerCarapaceArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>EOTF_DominionFabricator</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Steel>70</Steel>
      <Plasteel>55</Plasteel>
      <Gold>15</Gold>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <statBases>
      <WorkToMake>60000</WorkToMake>
      <MarketValue>1200</MarketValue>
      <MaxHitPoints>320</MaxHitPoints>
      <Mass>7</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>1.00</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
      <ArmorRating_Heat>0.54</ArmorRating_Heat>
      <Insulation_Cold>34</Insulation_Cold>
      <Insulation_Heat>10</Insulation_Heat>
      <EquipDelay>5</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.2</SlaveSuppressionOffset>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <useWornGraphicMask>True</useWornGraphicMask>
      <layers>
        <li>Middle</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <wornGraphicPath>Things/Pawn/Humanlike/Armor/OfficerArmor/OfficerArmor</wornGraphicPath>
      <tags Inherit="False">
        <li>EOTF_Armor_Officer</li>
      </tags>
      <renderNodeProperties>
        <li Class="EOTF.Core.DecalSystem.PawnRenderNodePropertiesOmni">
          <nodeClass>EOTF.Core.DecalSystem.PawnRenderNodeDecal</nodeClass>
          <workerClass>EOTF.Core.DecalSystem.PawnRenderNodeWorkerApparel</workerClass>
          <parentTagDef>ApparelBody</parentTagDef>
          <baseLayer>16</baseLayer>
          <texPaths>
            <li>Things/Decals/Officer/OfficerStar</li>
          </texPaths>
          <visibleFacing>
            <li>South</li>
            <li>North</li>
          </visibleFacing>
          <drawData>
            <scale>0.120</scale>
            <defaultData>
              <layer>23.555</layer>
              <offset>(0,0,-0.155)</offset>
              <flip>true</flip>
            </defaultData>
            <dataNorth>
              <layer>23.655</layer>
              <offset>(0,0,-0.148)</offset>
            </dataNorth>
            <bodyTypeScales>
              <Hulk>1.35</Hulk>
              <Fat>1.1</Fat>
              <Thin>0.9</Thin>
              <Female>1.05</Female>
            </bodyTypeScales>
          </drawData>
        </li>
      </renderNodeProperties>
    </apparel>
    <comps>
      <li Class="EOTF.Core.DecalSystem.CompPropertiesEditDecalMarker" />
    </comps>
    <techLevel>Spacer</techLevel>
    <thingCategories>
      <li>EOTF_Armor</li>
    </thingCategories>
    <tradeTags>
      <li>Armor</li>
      <li>EOTF_Armor</li>
    </tradeTags>
  </ThingDef>

