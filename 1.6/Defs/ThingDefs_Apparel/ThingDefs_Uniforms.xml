<Defs>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>TMG_MeridiaUniform_SuperHot</defName>
    <label>Meridia Guard Uniform (Desert)</label>
    <description>A standard Meridian duty uniform adapted for extreme heat. Stripped to the minimum needed for function, with a light weave that resists heat buildup.</description>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Pawn/Humanlike/Clothes/FieldUniformHell/FieldUniformHell</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>1.5</drawSize>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>5</weight>
          <only>(0.25,0.27,0.34)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.48,0.49,0.51)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.81,0.80,0.84)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.85,0.86,0.86)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>TMG_ExtremeWeatherUniforms</researchPrerequisite>
    </recipeMaker>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <costStuffCount>150</costStuffCount>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>5400</WorkToMake>
      <Mass>2.8</Mass>
      <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>1.75</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <PainShockThreshold>0.10</PainShockThreshold>
    </equippedStatOffsets>
    <apparel>
      <developmentalStageFilter>Child,Adult</developmentalStageFilter>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Clothes/FieldUniformHell/FieldUniformHell</wornGraphicPath>
      <useWornGraphicMask>True</useWornGraphicMask>
      <layers>
        <li>OnSkin</li>
      </layers>
      <tags>
        <li>TMG_MeridiaUniform</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
    <techLevel>Industrial</techLevel>
    <thingCategories Inherit="False">
      <li>TMG_Uniforms</li>
    </thingCategories>
    <tradeTags>
      <li>Clothing</li>
      <li>TMG_Uniforms</li>
    </tradeTags>
  </ThingDef>

