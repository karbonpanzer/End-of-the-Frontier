    </comps>
    <techLevel>Spacer</techLevel>
    <thingCategories>
      <li>EOTF_Armor</li>
    </thingCategories>
    <tradeTags>
      <li>Armor</li>
      <li>EOTF_Armor</li>
    </tradeTags>
  </ThingDef>

