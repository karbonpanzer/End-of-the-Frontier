<Defs>
  <ThingDef ParentName="ArmorMachineableBase">
    <defName>EOTF_HeavyCarapaceArmor</defName>
    <label>Heavy Carapace Armor</label>
    <description>A reinforced carapace armor set with additional plating over the standard configuration. Heavier and slower than carapace armor, but substantially more resistant to incoming fire. Used by assault troops expected to absorb significant punishment.</description>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <texPath>Things/Pawn/Humanlike/Armor/HeavyArmor/HeavyArmor</texPath>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>EOTF_HeavyCarapaceArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>EOTF_DominionFabricator</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Steel>80</Steel>
      <Plasteel>60</Plasteel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <statBases>
      <WorkToMake>60000</WorkToMake>
      <MarketValue>800</MarketValue>
      <MaxHitPoints>340</MaxHitPoints>
      <Mass>6</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>1.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.50</ArmorRating_Blunt>
      <ArmorRating_Heat>0.60</ArmorRating_Heat>
      <Insulation_Cold>34</Insulation_Cold>
      <Insulation_Heat>10</Insulation_Heat>
      <EquipDelay>3</EquipDelay>
    </statBases>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <layers>
        <li>Middle</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <wornGraphicPath>Things/Pawn/Humanlike/Armor/HeavyArmor/HeavyArmor</wornGraphicPath>
      <useWornGraphicMask>True</useWornGraphicMask>
      <soundWear>Wear_PowerArmor</soundWear>
      <soundRemove>Remove_PowerArmor</soundRemove>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <tags Inherit="False">
        <li>EOTF_Armor_Heavy</li>
        <li>EOTF_Armor_Heavy_Shocktrooper</li>
      </tags>
      <renderNodeProperties>
        <li Class="EOTF.Core.DecalSystem.PawnRenderNodePropertiesOmni">
          <nodeClass>EOTF.Core.DecalSystem.PawnRenderNodeDecal</nodeClass>
          <workerClass>EOTF.Core.DecalSystem.PawnRenderNodeWorkerApparel</workerClass>
          <parentTagDef>ApparelBody</parentTagDef>
          <baseLayer>16</baseLayer>
          <texPaths>
            <li>Things/Decals/Infantry/None</li>
          </texPaths>
          <visibleFacing>
            <li>South</li>
            <li>North</li>
          </visibleFacing>
          <drawData>
            <scale>0.120</scale>
            <defaultData>
              <layer>23.555</layer>
              <offset>(0,0,-0.155)</offset>
              <flip>true</flip>
            </defaultData>
            <dataNorth>
              <layer>23.655</layer>
              <offset>(0,0,-0.148)</offset>
            </dataNorth>
            <bodyTypeScales>
              <Hulk>1.35</Hulk>
              <Fat>1.1</Fat>
              <Thin>0.9</Thin>
              <Female>1.05</Female>
            </bodyTypeScales>
