  <!-- Carapace Helmet - Standard -->
  <ThingDef ParentName="ArmorMachineableBase">
    <defName>EOTF_CarapaceHelmet</defName>
    <label>Carapace Helmet</label>
    <description>A hard-shell combat helmet with a carapace outer layer and ballistic liner. Covers the skull and upper face. Standard head protection for Frontier combat personnel.</description>
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <researchPrerequisite>EOTF_CarapaceArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Helmets/LightHelmet/LightHelmet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <statBases>
      <WorkToMake>15750</WorkToMake>
      <MaxHitPoints>120</MaxHitPoints>
      <Mass>1</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.92</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
      <ArmorRating_Heat>0.46</ArmorRating_Heat>
      <Insulation_Cold>4</Insulation_Cold>
      <Insulation_Heat>2</Insulation_Heat>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <thingCategories>
      <li>EOTF_Helmets</li>
    </thingCategories>
    <costList>
      <Steel>40</Steel>
      <Plasteel>20</Plasteel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <apparel>
      <bodyPartGroups>
        <li>UpperHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Helmets/LightHelmet/LightHelmet</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useWornGraphicMask>True</useWornGraphicMask>
      <tags>
        <li>EOTF_Armor_Light</li>
        <li>EOTF_Armor_Light_Shocktrooper</li>
      </tags>
    </apparel>
    <comps>
      <li Class="EOTF.Core.DecalSystem.CompPropertiesEditDecalMarker" />
    </comps>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <tradeTags>
      <li>Armor</li>
      <li>EOTF_Armor</li>
    </tradeTags>
  </ThingDef>

