<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Carapace Armor - Standard Light Infantry Armor -->
  <ThingDef ParentName="ArmorMachineableBase">
    <defName>EOTF_CarapaceArmor</defName>
    <label>Carapace Armor</label>
    <description>A hardened armor set with segmented carapace plates bonded over a ballistic underlayer. Covers the torso and upper arms. Used by Frontier infantry who expect direct fire contact.</description>
    <techLevel>Spacer</techLevel>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Armor/LightArmor/LightArmor</texPath>         
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <recipeMaker>
      <researchPrerequisite>EOTF_CarapaceArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
    <statBases>
      <WorkToMake>60000</WorkToMake>
      <MarketValue>550</MarketValue>
      <MaxHitPoints>300</MaxHitPoints>
      <Mass>7</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.92</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
      <ArmorRating_Heat>0.54</ArmorRating_Heat>
      <Insulation_Cold>34</Insulation_Cold>
      <Insulation_Heat>10</Insulation_Heat>
      <EquipDelay>5</EquipDelay>
    </statBases>
    <thingCategories>
      <li>EOTF_Armor</li>
    </thingCategories>
    <costList>
      <Steel>60</Steel>
      <Plasteel>40</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <apparel>
      <useWornGraphicMask>True</useWornGraphicMask>
      <wornGraphicPath>Things/Pawn/Humanlike/Armor/LightArmor/LightArmor</wornGraphicPath>      
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
        <li>Neck</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <layers>
        <li>Middle</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <soundWear>Wear_PowerArmor</soundWear>
      <soundRemove>Remove_PowerArmor</soundRemove>
      <tags Inherit="False">
        <li>EOTF_Armor_Light</li>
        <li>EOTF_Armor_Light_Shocktrooper</li>
      </tags>
      <renderNodeProperties>
        <li Class="EOTF.Core.DecalSystem.PawnRenderNodePropertiesOmni">
          <nodeClass>EOTF.Core.DecalSystem.PawnRenderNodeDecal</nodeClass>
          <workerClass>EOTF.Core.DecalSystem.PawnRenderNodeWorkerApparel</workerClass>
          <parentTagDef>ApparelBody</parentTagDef>
          <baseLayer>23</baseLayer>
          <texPaths>
            <li>Things/Decals/Infantry/Arrowhead</li>
            <li>Things/Decals/Infantry/CrossedRifles</li>
            <li>Things/Decals/Infantry/CrossedSabers</li>
            <li>Things/Decals/Infantry/CrossedSwords</li>
            <li>Things/Decals/Infantry/Exoduster</li>
            <li>Things/Decals/Infantry/Lambda</li>
            <li>Things/Decals/Infantry/Skull</li>
            <li>Things/Decals/Infantry/Sword</li>
            <li>Things/Decals/Infantry/6Cav</li>
            <li>Things/Decals/Infantry/12Inf</li>
            <li>Things/Decals/Infantry/20Inf</li>
            <li>Things/Decals/Infantry/Keystone</li>
            <li>Things/Decals/Infantry/Club</li>
            <li>Things/Decals/Infantry/Heart</li>
            <li>Things/Decals/Infantry/Spade</li>
            <li>Things/Decals/Infantry/Diamond</li>
          </texPaths>
          <visibleFacing>
            <li>South</li>
            <li>North</li>
          </visibleFacing>
          <drawData>
            <scale>0.120</scale>
            <defaultData>
              <layer>23.555</layer>
              <offset>(0,0,-0.155)</offset>
              <flip>true</flip>
            </defaultData>
            <dataNorth>
              <layer>23.655</layer>
              <offset>(0,0,-0.148)</offset>
            </dataNorth>
            <bodyTypeScales>
              <Hulk>1.35</Hulk>
              <Fat>1.1</Fat>
              <Thin>0.9</Thin>
              <Female>1.05</Female>
            </bodyTypeScales>
          </drawData>
        </li>
      </renderNodeProperties>    
    </apparel>
    <comps>
      <li Class="EOTF.Core.DecalSystem.CompPropertiesEditDecalMarker" />
    </comps> 
    <tradeTags>
      <li>Armor</li>
      <li>EOTF_Armor</li>
    </tradeTags>
    <colorGenerator Class="ColorGenerator_Single">
      <color>(0.47, 0.47, 0.47)</color>
    </colorGenerator>
  </ThingDef>

